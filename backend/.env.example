# Real Rails PoC #35 API keys
# All keys are optional. The app runs safely with synthetic fallback if these are empty.
# Add your keys here to switch from MOCK → LIVE data

# NOAA Climate Data Online
# Register at: https://www.ncei.noaa.gov/cdo-web/token
NOAA_TOKEN=

# OpenWeatherMap
# Register at: https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY=

# UN Comtrade
# Register at: https://comtradeplus.un.org/
UN_COMTRADE_KEY=